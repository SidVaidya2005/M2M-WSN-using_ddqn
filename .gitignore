# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.installed.cfg
.eggs/
build/
dist/
sdist/
wheels/
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Type checking & linting ────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.flake8

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.coveragerc

# ── PyTorch / ML artifacts ────────────────────────────────────────────────────
*.onnx
# Track model weights inside results/
!results/**/*.pth
!results/**/*.pt

# ── Generated results (models, metrics, plots) ────────────────────────────────
# results/ is tracked — models, metrics JSON, and visualizations are committed.
!results/
!results/**

# ── Logging ───────────────────────────────────────────────────────────────────
logs/
*.log

# ── Local config overrides ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
config/config.local.yaml

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
runs.db

# ── Claude local overrides (personal, not shared) ─────────────────────────────
.claude.local.md
frontend/.claude.local.md
backend/.claude.local.md
.claude/settings.local.json

# ── OS & editors ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Matplotlib / visualization cache ──────────────────────────────────────────
# Ignore loose plots that land outside results/ (e.g. during dev)
*.gif

# Exception: keep images in results/, docs/, and frontend/static/
!results/**/*.png
!results/**/*.jpg
!results/**/*.jpeg
!docs/**/*.png
!docs/**/*.jpg
!frontend/static/img/**
