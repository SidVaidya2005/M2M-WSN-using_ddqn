# Environment Variables for WSN DDQN Training Platform

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Celery Configuration (for async training jobs)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Training Configuration
DEFAULT_EPISODES=100
DEFAULT_NUM_NODES=550
DEFAULT_LEARNING_RATE=0.0001
DEFAULT_GAMMA=0.99

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Database (optional, for tracking runs)
DATABASE_URL=sqlite:///runs.db

# App Settings
SECRET_KEY=your-secret-key-change-in-production
MAX_TRAINING_JOBS=3
